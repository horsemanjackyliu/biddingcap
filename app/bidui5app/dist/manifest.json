{
	"_version": "1.81.0",
	"sap.app": {
		"id": "bidui5app",
		"type": "application",
		"i18n": {
			"bundleUrl": "i18n/i18n.properties",
			"supportedLocales": [
				""
			]
		},
		"applicationVersion": {
			"version": "0.0.1"
		},
		"title": "{{appTitle}}",
		"description": "{{appDescription}}",
		"resources": "resources.json",
		"sourceTemplate": {
			"id": "@sap/generator-fiori:lrop",
			"version": "1.20.1",
			"toolsId": "6f26f58b-253c-4207-9952-f40f4b716496"
		},
		"dataSources": {
			"mainService": {
				"uri": "/service/auction/",
				"type": "OData",
				"settings": {
					"annotations": [],
					"odataVersion": "4.0"
				}
			}
		},
		"crossNavigation": {
			"inbounds": {
				"bidui5app-display": {
					"semanticObject": "bidui5app",
					"action": "display",
					"signature": {
						"parameters": {},
						"additionalParameters": "allowed"
					}
				}
			}
		}
	},
	"sap.ui": {
		"technology": "UI5",
		"icons": {
			"icon": "",
			"favIcon": "",
			"phone": "",
			"phone@2": "",
			"tablet": "",
			"tablet@2": ""
		},
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		}
	},
	"sap.ui5": {
		"flexEnabled": false,
		"dependencies": {
			"minUI5Version": "1.143.2",
			"libs": {
				"sap.m": {},
				"sap.ui.core": {},
				"sap.fe.templates": {}
			}
		},
		"contentDensities": {
			"compact": true,
			"cozy": true
		},
		"models": {
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": {
					"bundleName": "bidui5app.i18n.i18n",
					"supportedLocales": [
						""
					]
				}
			},
			"": {
				"dataSource": "mainService",
				"preload": true,
				"settings": {
					"operationMode": "Server",
					"autoExpandSelect": true,
					"earlyRequests": true
				}
			},
			"@i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"uri": "i18n/i18n.properties",
				"settings": {
					"supportedLocales": [
						""
					]
				}
			}
		},
		"resources": {
			"css": []
		},
		"routing": {
			"config": {},
			"routes": [
				{
					"pattern": ":?query:",
					"name": "AuctionsAucList",
					"target": "AuctionsAucList"
				},
				{
					"pattern": "AuctionsAuc({key}):?query:",
					"name": "AuctionsAucObjectPage",
					"target": "AuctionsAucObjectPage"
				},
				{
					"pattern": "AuctionsAuc({key})/attachments({key2}):?query:",
					"name": "AuctionsAuc_attachmentsObjectPage",
					"target": "AuctionsAuc_attachmentsObjectPage"
				}
			],
			"targets": {
				"AuctionsAucList": {
					"type": "Component",
					"id": "AuctionsAucList",
					"name": "sap.fe.templates.ListReport",
					"options": {
						"settings": {
							"contextPath": "/AuctionsAuc",
							"variantManagement": "Page",
							"navigation": {
								"AuctionsAuc": {
									"detail": {
										"route": "AuctionsAucObjectPage"
									}
								}
							},
							"controlConfiguration": {
								"@com.sap.vocabularies.UI.v1.LineItem": {
									"tableSettings": {
										"type": "ResponsiveTable"
									}
								}
							}
						}
					}
				},
				"AuctionsAucObjectPage": {
					"type": "Component",
					"id": "AuctionsAucObjectPage",
					"name": "sap.fe.templates.ObjectPage",
					"options": {
						"settings": {
							"editableHeaderContent": false,
							"contextPath": "/AuctionsAuc",
							"navigation": {
								"attachments": {
									"detail": {
										"route": "AuctionsAuc_attachmentsObjectPage"
									}
								}
							}
						}
					}
				},
				"AuctionsAuc_attachmentsObjectPage": {
					"type": "Component",
					"id": "AuctionsAuc_attachmentsObjectPage",
					"name": "sap.fe.templates.ObjectPage",
					"options": {
						"settings": {
							"editableHeaderContent": false,
							"contextPath": "/AuctionsAuc/attachments"
						}
					}
				}
			}
		},
		"flexBundle": false
	},
	"sap.fiori": {
		"registrationIds": [],
		"archeType": "transactional"
	},
	"sap.fe": {
		"app": {
			"enableLazyLoading": true
		}
	},
	"sap.cloud": {
		"public": true,
		"service": "bidauction.service"
	}
}